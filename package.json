{
  "name": "simple-login-form",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git@github.com:mintbandit/simple-login-form.git"
  },
  "scripts": {
    "dev": "concurrently \"pnpm dev:tailwind\" \"pnpm dev:backend\" \"pnpm dev:frontend\" \"pnpm dev:reload\"",
    "dev:tailwind": "tailwindcss -w -i src/backend/templates/index.css -o dist/styles.css",
    "dev:backend": "nodemon -w ./src -e ts,njk,css --exec ts-node src/backend/server.ts",
    "dev:frontend": "nodemon -w ./src -e ts --exec parcel build src/frontend/**/*.ts",
    "dev:reload": "pnpm livereload -w 2000 -e html,css,njk,ts",
    "test": "jest",
    "lint": "eslint",
    "check": "node check.js"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "@tsconfig/strictest": "^2.0.8",
    "@types/bcrypt": "^5.0.2",
    "@types/core-js": "^2.5.5",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.43",
    "@types/nunjucks": "^3.2.6",
    "@types/sqlite3": "^3.1.11",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.10.2",
    "eslint-config-standard-with-typescript": "^34.0.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^15.7.0",
    "eslint-plugin-promise": "^6.6.0",
    "jest": "^29.7.0",
    "livereload": "^0.9.3",
    "nodemon": "^2.0.22",
    "parcel": "^2.16.4",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "zod": "^3.25.76"
  },
  "engines": {
    "node": ">=18.9.1"
  },
  "dependencies": {
    "@fastify/cookie": "^8.3.0",
    "@fastify/formbody": "^7.4.0",
    "@fastify/static": "^6.12.0",
    "bcrypt": "^5.1.1",
    "daisyui": "^2.52.0",
    "dotenv": "^16.6.1",
    "fastify": "^4.17.0",
    "fastify-plugin": "^4.5.1",
    "nunjucks": "^3.2.4",
    "promised-sqlite3": "^2.1.0",
    "sqlite3": "^5.1.7",
    "uuid": "^9.0.0"
  }
}


